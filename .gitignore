# --- R Environment & IDE Files ---
.Rhistory
.RData
.Ruserdata
.Rproj.user/
.Rapp.history
.RDataTmp
*.Rproj

# --- System Junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- Large Binary/Data Files (Global Ignore) ---
# Prevents uploading files that exceed GitHub's 100MB limit
*.rds
*.Rdata
*.gz
*.tar
*.mtx
*.zip
*.7z

# --- Folder Specific Rules ---

# 1. Raw_Data: Ignore all downloaded sequencing/matrix data
Raw_Data/**/*
!Raw_Data/.gitkeep

# 2. Processed_Objects: Ignore large intermediate Seurat/Monocle objects
Processed_Objects/*
!Processed_Objects/.gitkeep

# 3. Results: Ignore generated PDF/PNG/CSV outputs
# (We want users to run the scripts to generate these)
Results/**/*
!Results/.gitkeep
!Results/Result_Supporting_Files/.gitkeep

# 4. Environment: Ignore local library but keep the lockfile
Environment/library/
Environment/python/
Environment/staging/

# --- Essential Exceptions (FILES WE MUST KEEP) ---

# Keep all Scripts and Documentation
!*.R
!*.Rmd
!*.md
!LICENSE

# Force inclusion of small reference files required for analysis
!External_Data_File/human_chicken_orthologs.txt
!External_Data_File/Hsapiens_Ggallus_Ortholog_Mapping_Ensembl.txt
!External_Data_File/Richard2016_Bulk_T2EC.csv
!External_Data_File/Immature_Ery.csv
!External_Data_File/Mature_Ery.csv

# Keep environment reproducibility files
!Environment/session_info.txt
!Environment/renv.lock
!Environment/activate.R
!Environment/settings.json